// src/syntagmax/extractors/obsidian.lark
?start: req

req: _REQ_BEGIN content fields yaml_block

_REQ_BEGIN: /\[REQ\]/i

content: [content_text]
content_text: /(.|\n)+?(?=\r?\n\[|```yaml|$)/s

fields: (field)*
field: _NL _LSQB AID _RSQB content

yaml_block: _NL? _YAML_BEGIN [yaml_content] _YAML_END
yaml_content: /(.|\n)+?(?=```)/s

_LSQB: "["
_RSQB: "]"
_YAML_BEGIN: "```yaml"
_YAML_END: "```"
_NL: /\r?\n/

AID: /[^\]]+/

%import common.WS_INLINE
%ignore WS_INLINE
